# ─── Oracle Cloud F1 updater config ─────────────────────────────────────────
# Copy to ".env" and fill in. setup.sh creates this file if missing.

# Where to publish:  github | oracle | github,oracle  (comma = both)
DEST=github

# Seasons to keep in sync, and refresh behaviour
SEASONS=2024,2025,2026
REFRESH_DAYS=2          # re-process sessions newer than N days (late corrections)
MAX_PER_RUN=0           # cap sessions per run (0 = unlimited; the VM isn't time-limited)
TELEMETRY_WORKERS=4     # telemetry threads per session (Ampere A1 has up to 4 OCPU)

# ─── GitHub destination (DEST includes "github") ────────────────────────────
GITHUB_DATA_REPO=https://github.com/Sadme69/telemetry_F1.git
GITHUB_BRANCH=main
# Fine-grained PAT with Contents: Read & Write on the data repo.
# NOTE: pushing .github/workflows/* additionally needs Workflows: Write — this
# updater never writes workflow files, so Contents write is enough.
GITHUB_TOKEN=
GITHUB_CLONE_DIR=./_data_repo
GIT_AUTHOR_NAME=f1-oracle-updater
GIT_AUTHOR_EMAIL=f1-oracle-updater@users.noreply.github.com

# ─── Oracle Object Storage destination (DEST includes "oracle") ─────────────
# S3-compatible endpoint:  https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
ORACLE_S3_ENDPOINT=
ORACLE_REGION=us-ashburn-1
ORACLE_BUCKET=f1timingdata
# "Customer Secret Key" from OCI console (Identity > Users > your user > Customer Secret Keys)
ORACLE_S3_ACCESS_KEY=
ORACLE_S3_SECRET_KEY=
